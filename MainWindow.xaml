<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Clipora.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Clipora"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Clipora">

    <Grid Background="#0a0a0c">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#111114" BorderBrush="#222228" BorderThickness="0,0,0,1" Padding="16,12">
            <Grid>
                <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                    <TextBlock Text="📋 Clipora"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#818cf8"/>
                    <TextBlock Text="Ctrl+Shift+V to open"
                               FontSize="10"
                               Foreground="#63636e"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" VerticalAlignment="Center">
                    <Button x:Name="MenuButton"
                            Content="⋯"
                            FontSize="18"
                            Width="36"
                            Height="36"
                            Background="#18181c"
                            Foreground="#d4d4d8"
                            BorderThickness="1"
                            BorderBrush="#222228"
                            CornerRadius="18"
                            Padding="0,-4,0,0">
                        <Button.Flyout>
                            <MenuFlyout Placement="Bottom">
                                <ToggleMenuFlyoutItem x:Name="AutoCaptureToggle"
                                                      Text="Auto-capture clipboard"
                                                      Click="AutoCaptureToggle_Click"
                                                      ToolTipService.ToolTip="When enabled, any text you copy is automatically saved as a snippet. Turn this off if you only want to add snippets manually with the + button."/>
                                <MenuFlyoutSubItem Text="History cap">
                                    <MenuFlyoutItem Text="50" Click="HistoryCap50_Click"/>
                                    <MenuFlyoutItem Text="100" Click="HistoryCap100_Click"/>
                                    <MenuFlyoutItem Text="Unlimited" Click="HistoryCapUnlimited_Click"/>
                                </MenuFlyoutSubItem>
                                <MenuFlyoutSeparator/>
                                <MenuFlyoutItem Text="Import…" Click="Import_Click"/>
                                <MenuFlyoutItem Text="Export…" Click="Export_Click"/>
                                <MenuFlyoutSeparator/>
                                <MenuFlyoutItem Text="Clear history" Click="ClearHistory_Click"/>
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                    <Button x:Name="AddButton"
                            Content="＋"
                            Click="AddButton_Click"
                            Background="#6366f1"
                            Foreground="White"
                            FontSize="20"
                            FontWeight="Bold"
                            Width="40"
                            Height="40"
                            CornerRadius="20"
                            BorderThickness="0"
                            Padding="0,-4,0,0">
                        <Button.Resources>
                            <ResourceDictionary>
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#818cf8"/>
                                <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#4f46e5"/>
                            </ResourceDictionary>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Search -->
        <Border Grid.Row="1" Background="#111114" Padding="12,8,12,4">
            <TextBox x:Name="SearchBox"
                     PlaceholderText="Search snippets…"
                     TextChanged="SearchBox_TextChanged"/>
        </Border>

        <!-- Category filters -->
        <Border Grid.Row="2" Background="#111114" Padding="12,4,12,8">
            <ScrollViewer HorizontalScrollMode="Auto"
                          HorizontalScrollBarVisibility="Hidden"
                          VerticalScrollBarVisibility="Disabled"
                          VerticalScrollMode="Disabled">
                <StackPanel x:Name="CategoryFilterPanel" Orientation="Horizontal" Spacing="6"/>
            </ScrollViewer>
        </Border>

        <!-- Snippets list -->
        <ListView x:Name="SnippetsList"
                  Grid.Row="3"
                  Padding="12,8,12,8"
                  Background="Transparent"
                  SelectionMode="None"
                  CanReorderItems="True"
                  AllowDrop="True"
                  CanDragItems="True"
                  ShowsScrollingPlaceholders="False"
                  DragItemsCompleted="SnippetsList_DragItemsCompleted">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0,0,0,8"/>
                    <Setter Property="MinHeight" Value="0"/>
                    <Setter Property="Background" Value="Transparent"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="local:Snippet">
                    <Border Background="#18181c"
                            BorderBrush="#222228"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="5"
                                       Text="{x:Bind Text, Mode=OneWay}"
                                       TextWrapping="Wrap"
                                       Foreground="#d4d4d8"
                                       Margin="0,0,0,8"/>

                            <Border Grid.Row="1" Grid.Column="0"
                                    Background="#222228"
                                    CornerRadius="4"
                                    Padding="6,2"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Visibility="{x:Bind CategoryVisibility, Mode=OneWay}">
                                <TextBlock Text="{x:Bind Category, Mode=OneWay}"
                                           FontSize="10"
                                           Foreground="#818cf8"/>
                            </Border>

                            <Button Grid.Row="1" Grid.Column="1"
                                    Content="{x:Bind PinIcon, Mode=OneWay}"
                                    Click="PinButton_Click"
                                    FontSize="14"
                                    Width="32" Height="32"
                                    Margin="4,0,4,0"
                                    Background="#222228"
                                    Foreground="#d4d4d8"
                                    BorderThickness="0"
                                    CornerRadius="6"/>
                            <Button Grid.Row="1" Grid.Column="2"
                                    Content="📋"
                                    Click="CopyButton_Click"
                                    FontSize="14"
                                    Width="32" Height="32"
                                    Margin="4,0,4,0"
                                    Background="#6366f1"
                                    Foreground="White"
                                    BorderThickness="0"
                                    CornerRadius="6"/>
                            <Button Grid.Row="1" Grid.Column="3"
                                    Content="✏️"
                                    Click="EditButton_Click"
                                    FontSize="14"
                                    Width="32" Height="32"
                                    Margin="4,0,4,0"
                                    Background="#222228"
                                    Foreground="#d4d4d8"
                                    BorderThickness="0"
                                    CornerRadius="6"/>
                            <Button Grid.Row="1" Grid.Column="4"
                                    Content="🗑️"
                                    Click="DeleteButton_Click"
                                    FontSize="14"
                                    Width="32" Height="32"
                                    Margin="4,0,4,0"
                                    Background="#ef4444"
                                    Foreground="White"
                                    BorderThickness="0"
                                    CornerRadius="6"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Footer -->
        <Border Grid.Row="4"
                Background="#111114"
                BorderBrush="#222228"
                BorderThickness="0,1,0,0"
                Padding="10,6,10,6">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="14">
                <HyperlinkButton Content="Made by EERIE"
                                 NavigateUri="https://eeriegoesd.com"
                                 FontSize="12"
                                 Foreground="#d4d4d8"
                                 Padding="0"
                                 VerticalAlignment="Center"/>
                <HyperlinkButton Content="Report Issue"
                                 NavigateUri="https://github.com/EerieGoesD/clipora/issues/new"
                                 FontSize="12"
                                 Foreground="#ef4444"
                                 Padding="0"
                                 VerticalAlignment="Center"/>
                <HyperlinkButton Content="Suggest Feature"
                                 NavigateUri="https://github.com/EerieGoesD/clipora/discussions/new?category=ideas"
                                 FontSize="12"
                                 Foreground="#22c55e"
                                 Padding="0"
                                 VerticalAlignment="Center"/>
                <HyperlinkButton Content="☕ Support This Project"
                                 NavigateUri="https://buymeacoffee.com/eeriegoesd"
                                 FontSize="12"
                                 Foreground="#facc15"
                                 Padding="0"
                                 VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
