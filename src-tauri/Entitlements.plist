<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Required for the Mac App Store. -->
  <key>com.apple.security.app-sandbox</key>
  <true/>
  <!-- Lets Import/Export read and write the file the user picks in the dialog. -->
  <key>com.apple.security.files.user-selected.read-write</key>
  <true/>
  <!-- StoreKit (in-app purchase) needs outbound network access. -->
  <key>com.apple.security.network.client</key>
  <true/>
  <!-- App Store identity (Team ID R8G3Q53T4G). -->
  <key>com.apple.application-identifier</key>
  <string>R8G3Q53T4G.com.eeriegoesd.clipora</string>
  <key>com.apple.developer.team-identifier</key>
  <string>R8G3Q53T4G</string>
</dict>
</plist>
